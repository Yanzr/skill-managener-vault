# universal-image Skill 配置示例
# 复制本文件为 .env 后填写真实值
# 安装位置：~/.claude/skills/universal-image/.env

# === AI 生图（如需使用 AI 引擎则必填）===
# OpenAI 兼容的中转站地址（可包含或不包含 /v1，脚本会自动适配）
IMAGE_API_BASE_URL=https://your-proxy.example.com/v1
# 中转站密钥
IMAGE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxx
# 模型名称，默认 gpt-image-2
IMAGE_MODEL=gpt-image-2

# === PlantUML（可选，默认走 plantuml.com 公共服务）===
# 私有部署时覆盖此项
PLANTUML_SERVER_URL=https://www.plantuml.com/plantuml

# === 输出 ===
# 输出目录，相对路径基于运行 Claude Code 时的工作目录
OUTPUT_DIR=./output
# 默认图片格式：png / svg / jpg（AI 生图仅支持 png/jpg）
DEFAULT_FORMAT=png
